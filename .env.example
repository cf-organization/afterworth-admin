# afterworth-admin — client-safe env ONLY. There is NO service_role / secret key in this app, ever.
# The app calls Supabase RPCs with the signed-in admin's own JWT (RLS + the RPC-internal gates apply).
NEXT_PUBLIC_SUPABASE_URL=https://yiaavvkulrpqkkbqhwit.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key_here

# Server-ONLY (NOT NEXT_PUBLIC — the browser never sees it). Base URL of afterworth-api, which the
# /api/claim-evidence BFF route proxies to server-to-server for the claims evidence viewer (C1.6b). This
# keeps the console CSP at connect-src 'self' (the browser only ever talks to this app's own origin). The
# afterworth-api endpoint holds the service_role key and does the storage read; this app still holds no key.
AFTERWORTH_API_URL=https://afterworth-api.vercel.app
